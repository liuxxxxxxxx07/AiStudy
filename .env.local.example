# Configure the payment server URL (used by the frontend)
# For local development with the payment server running on port 3001:
NEXT_PUBLIC_PAYMENT_SERVER_URL=http://localhost:3001

# For production (deploy payment-server separately and set this URL):
# NEXT_PUBLIC_PAYMENT_SERVER_URL=https://payments.yourdomain.com

# OpenRouter API key - REQUIRED for AI features
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE

# Supabase Auth - REQUIRED for login
# Create a free project at: https://supabase.com
# Go to Project Settings > API to find these keys
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE